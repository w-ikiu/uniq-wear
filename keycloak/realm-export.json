{
  "realm": "uniqwear",
  "displayName": "UniqWear",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "bruteForceProtected": true,
  "accessTokenLifespan": 300,
  "refreshTokenMaxReuse": 0,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "administrator — pelny dostep do zarzadzania produktami i zamowieniami"
      },
      {
        "name": "user",
        "description": "zwykly uzytkownik — moze przegladac produkty i skladac zamowienia"
      },
      {
        "name": "moderator",
        "description": "moderator — moze zatwierdzac i odrzucac recenzje uzytkownikow"
      }
    ]
  },
  "clients": [
    {
      "clientId": "frontend-spa",
      "name": "UniqWear Frontend (SPA)",
      "description": "klient publiczny react — uzywa authorization code + pkce",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:5174/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:5174"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "ssr-panel",
      "name": "UniqWear SSR Admin Panel",
      "description": "klient poufny ssr — uzywa authorization code z sesja serwerowa",
      "enabled": true,
      "publicClient": false,
      "secret": "ssr-panel-secret-dev",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:4000/*"
      ],
      "webOrigins": [
        "http://localhost:4000"
      ]
    },
    {
      "clientId": "b2b-service",
      "name": "UniqWear B2B Service",
      "description": "klient backend-2-backend — uzywa client credentials (brak uzytkownika)",
      "enabled": true,
      "publicClient": false,
      "secret": "b2b-service-secret-dev",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "redirectUris": []
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@uniqwear.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "UniqWear",
      "credentials": [
        {
          "type": "password",
          "value": "Admin1234!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "user"
      ]
    },
    {
      "username": "user",
      "email": "user@uniqwear.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "User1234!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "config": {
        "clientId": "REPLACE_WITH_GOOGLE_CLIENT_ID",
        "clientSecret": "REPLACE_WITH_GOOGLE_CLIENT_SECRET",
        "syncMode": "IMPORT",
        "useJwksUrl": "true"
      }
    }
  ]
}