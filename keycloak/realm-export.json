{
  "realm": "uniqwear",
  "displayName": "UniqWear",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "bruteForceProtected": true,
  "accessTokenLifespan": 300,
  "refreshTokenMaxReuse": 0,
  "defaultRoles": ["user"],
  "smtpServer": {
    "host": "mailhog",
    "port": "1025",
    "from": "noreply@uniqwear.com",
    "fromDisplayName": "UniqWear",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  },
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyInitialCounter": 0,
  "otpPolicyDigits": 6,
  "otpPolicyLookAheadWindow": 1,
  "otpPolicyPeriod": 30,
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false,
      "priority": 10
    },
    {
      "alias": "UPDATE_PASSWORD",
      "name": "Update Password",
      "providerId": "UPDATE_PASSWORD",
      "enabled": true,
      "defaultAction": false,
      "priority": 30
    },
    {
      "alias": "VERIFY_EMAIL",
      "name": "Verify Email",
      "providerId": "VERIFY_EMAIL",
      "enabled": true,
      "defaultAction": false,
      "priority": 50
    },
    {
      "alias": "UPDATE_PROFILE",
      "name": "Update Profile",
      "providerId": "UPDATE_PROFILE",
      "enabled": true,
      "defaultAction": false,
      "priority": 40
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "administrator — pelny dostep do zarzadzania produktami i zamowieniami"
      },
      {
        "name": "user",
        "description": "zwykly uzytkownik — moze przegladac produkty i skladac zamowienia"
      },
      {
        "name": "moderator",
        "description": "moderator — moze zatwierdzac i odrzucac recenzje uzytkownikow"
      }
    ]
  },
  "clients": [
    {
      "clientId": "frontend-spa",
      "name": "UniqWear Frontend (SPA)",
      "description": "klient publiczny react — uzywa authorization code + pkce",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:5174/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:5174"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "picture",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "picture",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "picture",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "ssr-panel",
      "name": "UniqWear SSR Admin Panel",
      "description": "klient poufny ssr — uzywa authorization code z sesja serwerowa",
      "enabled": true,
      "publicClient": false,
      "secret": "ssr-panel-secret-dev",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:4000/*"
      ],
      "webOrigins": [
        "http://localhost:4000"
      ]
    },
    {
      "clientId": "b2b-service",
      "name": "UniqWear B2B Service",
      "description": "klient backend-2-backend — uzywa client credentials (brak uzytkownika)",
      "enabled": true,
      "publicClient": false,
      "secret": "b2b-service-secret-dev",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "redirectUris": []
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@uniqwear.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "UniqWear",
      "credentials": [
        {
          "type": "password",
          "value": "Admin1234!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "user"
      ]
    },
    {
      "username": "user",
      "email": "user@uniqwear.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "User1234!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    },
    {
      "username": "moderator1",
      "email": "moderator1@uniqwear.dev",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Moderator",
      "lastName": "UniqWear",
      "credentials": [
        {
          "type": "password",
          "value": "Mod1234!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "moderator",
        "user"
      ]
    }
  ],
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "config": {
        "clientId": "REPLACE_WITH_GOOGLE_CLIENT_ID",
        "clientSecret": "REPLACE_WITH_GOOGLE_CLIENT_SECRET",
        "syncMode": "IMPORT",
        "useJwksUrl": "true"
      }
    }
  ],
  "identityProviderMappers": [
    {
      "name": "google-picture",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "claim": "picture",
        "user.attribute": "picture"
      }
    },
    {
      "name": "google-given-name",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "claim": "given_name",
        "user.attribute": "firstName"
      }
    }
  ]
}