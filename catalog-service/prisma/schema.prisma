// konfiguracja generatora klienta
generator client {
  provider = "prisma-client-js"
}

// konfiguracja zrodla danych (postgres)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// model kategorii (wymog: min 2 modele z relacjami)
model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

// glowny model produktu
model Product {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  categoryId  Int
  category    Category  @relation(fields: [categoryId], references: [id])
  variants    Variant[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// model wariantu (np. konkretny rozmiar i kolor buta)
// zawiera scisle dane magazynowe i cenowe
model Variant {
  id        Int      @id @default(autoincrement())
  sku       String   @unique
  price     Decimal
  stock     Int      @default(0)
  size      String?
  color     String?
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
}