// konfiguracja generatora klienta
generator client {
  provider = "prisma-client-js"
}

// polaczenie z bazy danych
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// t4: model kategorii menu (np. burgery, napoje)
model Category {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  items     MenuItem[]
}

// t4: glowny model pozycji w menu
model MenuItem {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  categoryId  Int
  category    Category   @relation(fields: [categoryId], references: [id])
  variants    Variant[]
  modifiers   Modifier[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// t4: warianty (np. mala/duza kawa)
model Variant {
  id         Int      @id @default(autoincrement())
  sku        String   @unique
  price      Decimal
  size       String?
  menuItemId Int
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}

// wymaganie funkcjonalne: modyfikatory (np. dodatkowy sos, bekon)
model Modifier {
  id         Int      @id @default(autoincrement())
  name       String
  price      Decimal
  menuItemId Int
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
}